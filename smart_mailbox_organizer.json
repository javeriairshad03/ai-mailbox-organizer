      "parameters": {
        "inputText": "=Subject:  {{ $json.Subject }}\nContent: {{ $json.snippet }}",
        "categories": {
          "categories": [
            {
              "category": "OTPs & Confirm. Codes",
              "description": "This is any email having keywords or anythig like Multi-factor authentication, 2FA, one-time passwords, or numeric/alphanumeric verification strings, then classify them here."
            },
            {
              "category": "PROMOTIONS",
              "description": "Any emails like Marketing newsletters, sales offers, \"off\" percentages, coupons, or subscription-based content (e.g., Pinterest/Canva updates), .educational offers, career updates, course recommendations (like Coursera or IBM) or career grouwth offers, and brand announcements."
            },
            {
              "category": "SPAM",
              "description": "Obvious junk mail, \"Lottery winner,\" \"Urgent\" fake claims, or unsolicited irrelevant offers."
            },
            {
              "category": "SOCIALS",
              "description": "Any email Notifications from LinkedIn, Facebook, Instagram, or social platform messages/comments."
            },
            {
              "category": "Reciepts",
              "description": "Any emails regarding Transaction confirmations, invoices, Easypaisa/bank payment alerts, or \"Money Transfer\" successful messages, should be categorized under here."
            },
            {
              "category": "Login Alerts",
              "description": "This is any email or Notifications of new sign-ins, security alerts from Google/Microsoft/Apple/Instagram/Facebook or any socials, account recovery warnings, or \"unusual activity\" reports."
            },
            {
              "category": "Personal",
              "description": "Strictly for direct, one-to-one emails from a real human being. If the email is sent by a company, a platform, an automated system, or a school/service (like IBM, Coursera, LinkedIn), it is NOT Personal. If it is sent from a 'no-reply' address, it is NEVER Personal."
            },
            {
              "category": "Learning & Newsletters",
              "description": "Any automated email about courses, certificates, or professional updates."
            }
          ]
        },
        "options": {
          "systemPromptTemplate": "You are a text classifier. Return only the JSON object. Do not use Markdown code blocks or backticks (```). Don't explain, and Do not include any text before or after the JSON.",
