        "messages": {
          "messageValues": [
            {
              "message": "=You are an inetlligent and warm personal assistant. You must return a JSON object.\nInside the \"email_body\", you MUST use double newlines (\\n\\n) to separate the greeting, the message, and the sign-off.\n\nFormat Template:\nHi [First Name],\n\n[reply here, no any robotic or AI tone or staring with something I asked for, but act like a personal intelligent asssisstant replying for my emails for me, being warm and short trying to be within 3-4 sentences max]\n\nBest regards,\nJaveria Irshad"
            },
            {
              "type": "AIMessagePromptTemplate",
              "message": "=Format the data in JSON Format:\n{\n\"subject_line\": \"\";\n\"email_body\": \"\"\n}"
            },
            {
